generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  cnes Int @id
  cnpj Int @unique

  hire_date DateTime @default(now())

  state String

  procedures Procedure[]
  reports    Report[]
}

model Procedure {
  aih Int @id

  date_proc DateTime

  val_h Int @default(0)
  val_u Int @default(0)
  val_p Int @default(0)

  hospital_cnes Int
  hospital      Client @relation(fields: [hospital_cnes], references: [cnes])

  procedureTypeid Int
  procedureType   ProcedureType @relation(fields: [procedureTypeid], references: [id])

  @@index([hospital_cnes, procedureTypeid])
}

model ProcedureType {
  id Int @id @default(autoincrement())

  valTunep    Float
  description String?

  procedures Procedure[]
}

model Report {
  id Int @id @default(autoincrement())

  pdf          Bytes
  data_created DateTime @default(now())

  client_cnes Int
  client      Client @relation(fields: [client_cnes], references: [cnes])

  @@index([client_cnes])
}
